# EvalDoc — Variables de Entorno
# Copia este archivo a .env.local y completa los valores

# ============================================================================
# SUPABASE
# ============================================================================
# Crea un proyecto en https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ... (copiar de Supabase Settings > API)
SUPABASE_SERVICE_ROLE_KEY=eyJ... (copiar de Supabase Settings > API, service_role)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# ============================================================================
# VERCEL BLOB
# ============================================================================
# Crea un token en https://vercel.com/account/tokens
BLOB_READ_WRITE_TOKEN=vercel_blob_xxx_yyy

# ============================================================================
# AUTENTICACIÓN JWT
# ============================================================================
# Genera una clave aleatoria de al menos 32 caracteres
JWT_SECRET=tu-clave-secreta-super-larga-y-aleatoria-aqui

# Bootstrap del admin (solo para /api/system/bootstrap)
ADMIN_BOOTSTRAP_SECRET=admin-bootstrap-secret-super-secreto

# ============================================================================
# RESEND (Correos)
# ============================================================================
# Crea una cuenta en https://resend.com
RESEND_API_KEY=re_xxx_yyy
RESEND_FROM_EMAIL=noreply@tu-dominio.edu.co

# ============================================================================
# APP
# ============================================================================
# URL pública de la aplicación (usada en enlaces de correos)
NEXT_PUBLIC_APP_URL=http://localhost:3000
